PROJECT_NAME=s3-platform
APP_ENV=development
API_IMAGE=harborshield-api:local
WORKER_IMAGE=harborshield-worker:local
BLOBNODE_IMAGE=harborshield-blobnode:local
FRONTEND_IMAGE=harborshield-frontend:local
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2-alpine
CLAMAV_IMAGE=clamav/clamav:stable
PROMETHEUS_IMAGE=prom/prometheus:v2.53.4
WEBHOOK_RECEIVER_IMAGE=python:3.12-alpine
COMPOSE_LOG_MAX_SIZE=10m
COMPOSE_LOG_MAX_FILES=3

API_PORT=8080
FRONTEND_PORT=3000

POSTGRES_DB=s3platform
POSTGRES_USER=s3platform
POSTGRES_PASSWORD=change_me
POSTGRES_PASSWORD_FILE=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_PASSWORD_FILE=

JWT_SECRET=change_me_long_random_value
JWT_SECRET_FILE=
JWT_ISSUER=s3-platform
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me_now
ADMIN_BOOTSTRAP_PASSWORD_FILE=

STORAGE_BACKEND=local
STORAGE_ROOT=/data
STORAGE_MASTER_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
STORAGE_MASTER_KEY_FILE=
STORAGE_NODE_SHARED_SECRET=change_me_blobnode_secret
STORAGE_NODE_SHARED_SECRET_FILE=
STORAGE_NODE_TLS_CA_FILE=
STORAGE_NODE_TLS_CLIENT_CERT_FILE=
STORAGE_NODE_TLS_CLIENT_KEY_FILE=
BLOBNODE_TLS_CERT_FILE=
BLOBNODE_TLS_KEY_FILE=
BLOBNODE_TLS_CLIENT_CA_FILE=
BLOBNODE_TLS_CERTS_DIR=./deploy/certs/blobnode
STORAGE_DISTRIBUTED_ENDPOINTS=
STORAGE_DISTRIBUTED_REPLICAS=0
STORAGE_DEFAULT_CLASS=standard
S3_REGION=us-east-1
S3_DEFAULT_TENANT=default
S3_PRESIGN_TTL=15m
MAX_UPLOAD_SIZE_BYTES=104857600
SOFT_DELETE_RETENTION=24h

ENABLE_CLAMAV=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
MALWARE_SCAN_MODE=advisory

OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CLIENT_SECRET_FILE=
OIDC_REDIRECT_URL=
OIDC_SCOPES=openid,email,profile
OIDC_ROLE_CLAIM=
OIDC_ROLE_MAP=
OIDC_DEFAULT_ROLE=admin

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
ADMIN_IP_ALLOWLIST=
